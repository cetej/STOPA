{
  "_version": "1.1",
  "_description": "Reactive skill chain definitions. After a skill completes, the chain engine checks these rules and injects context for the next step. Jarvis principle: maximize 'auto' chains, minimize human gates.",
  "chains": [
    {
      "trigger": { "skill": "critic", "status_pattern": "PASS|passed|no.*(issues|problems)|clean|approved|all good" },
      "next": "/verify last changes",
      "condition": "auto",
      "description": "After critic passes, verify changes work end-to-end"
    },
    {
      "trigger": { "skill": "brainstorm", "status_pattern": "DONE|done|complete|spec ready|handoff" },
      "next": "/orchestrate",
      "condition": "auto",
      "description": "After brainstorm produces a spec, orchestrate implementation automatically"
    },
    {
      "trigger": { "skill": "orchestrate", "status_pattern": "DONE|done|complete|all subtasks" },
      "next": "/checkpoint save",
      "condition": "auto",
      "description": "After orchestration completes, save progress automatically"
    },
    {
      "trigger": { "skill": "verify", "status_pattern": "PASS|passed|verified|works|proven" },
      "next": "/scribe learning",
      "condition": "auto",
      "description": "After verification passes, record what worked as a learning"
    },
    {
      "trigger": { "skill": "scribe", "status_pattern": "DONE|done|recorded|saved|written" },
      "next": "/compile --incremental",
      "condition": "auto",
      "description": "After scribe records a learning, compile it into wiki automatically"
    },
    {
      "trigger": { "skill": "compile", "status_pattern": "DONE|done|complete|compiled|wiki updated" },
      "next": "/checkpoint save",
      "condition": "auto",
      "description": "After compile updates wiki, checkpoint the knowledge state"
    },
    {
      "trigger": { "skill": "deepresearch", "status_pattern": "DONE|done|complete|report ready" },
      "next": "/scribe learning",
      "condition": "auto",
      "description": "After deep research completes, record key findings as learnings"
    },
    {
      "trigger": { "skill": "project-init", "status_pattern": "DONE|done|created|initialized" },
      "next": "Register project in ~/.claude/memory/projects.json",
      "condition": "auto",
      "description": "After initializing a project, register it in the project registry"
    },
    {
      "trigger": { "skill": "fix-issue", "status_pattern": "DONE|done|committed|fixed" },
      "next": "/critic",
      "condition": "auto",
      "description": "After fixing an issue, run quality review"
    },
    {
      "trigger": { "skill": "autofix", "status_pattern": "DONE|done|pushed|fixed" },
      "next": "/verify",
      "condition": "auto",
      "description": "After autofix, verify the fix works end-to-end"
    },
    {
      "trigger": { "skill": "tdd", "status_pattern": "GREEN|green|all tests pass" },
      "next": "/critic",
      "condition": "auto",
      "description": "After TDD green phase, run quality review automatically"
    },
    {
      "trigger": { "skill": "build-project", "status_pattern": "DONE|done|complete" },
      "next": "/checkpoint save",
      "condition": "auto",
      "description": "After building a project, checkpoint the state"
    },
    {
      "trigger": { "skill": "evolve", "status_pattern": "DONE|done|complete|applied|graduated" },
      "next": "/compile --incremental",
      "condition": "auto",
      "description": "After evolve graduates rules, recompile wiki to reflect changes"
    },
    {
      "trigger": { "skill": "self-evolve", "status_pattern": "DONE|done|complete|improved" },
      "next": "/checkpoint save",
      "condition": "auto",
      "description": "After self-evolve improves a skill, checkpoint the improvement"
    },
    {
      "trigger": { "skill": "autoresearch", "status_pattern": "PIVOT|pivot|plateau|stuck|no improvement" },
      "next": "/deepresearch",
      "condition": "auto",
      "description": "When autoresearch hits plateau or pivots, auto-trigger deep literature review"
    },
    {
      "trigger": { "skill": "autoresearch", "status_pattern": "DONE|done|complete|best score" },
      "next": "/scribe learning",
      "condition": "auto",
      "description": "After autoresearch completes, record findings as learnings"
    },
    {
      "trigger": { "skill": "autoloop", "status_pattern": "DONE|done|complete|optimized" },
      "next": "/scribe learning",
      "condition": "auto",
      "description": "After autoloop completes, record optimization findings"
    },
    {
      "trigger": { "skill": "sweep", "status_pattern": "DONE|done|complete|cleaned" },
      "next": "/scribe learning",
      "condition": "auto",
      "description": "After sweep cleans entropy, record discovered patterns as learnings"
    },
    {
      "trigger": { "skill": "peer-review", "status_pattern": "DONE|done|complete|reviewed" },
      "next": "/scribe learning",
      "condition": "auto",
      "description": "After peer review completes, record review findings as learnings"
    }
  ]
}
