{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/checkpoint-check.sh",
            "timeout": 5,
            "statusMessage": "Checking checkpoint..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/memory-maintenance.sh",
            "timeout": 5,
            "statusMessage": "Checking memory health..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-compact.sh",
            "timeout": 3,
            "statusMessage": "Post-compaction checkpoint reminder"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/scribe-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/task-completed.sh",
            "timeout": 3,
            "statusMessage": "Task completed — checking for learnings..."
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-failure.sh",
            "timeout": 3,
            "statusMessage": "API error — checking recovery..."
          }
        ]
      }
    ]
  }
}
