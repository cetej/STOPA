{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "STOPA_HOOK_PROFILE": "standard",
    "STOPA_VERBOSITY": "standard"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/checkpoint-check.sh",
            "timeout": 5,
            "statusMessage": "Checking checkpoint..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/memory-maintenance.sh",
            "timeout": 5,
            "statusMessage": "Checking memory health..."
          },
          {
            "type": "command",
            "command": "python .claude/hooks/auto-scribe.py",
            "timeout": 15,
            "statusMessage": "Analyzing previous session..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/memory-brief.sh",
            "timeout": 5,
            "statusMessage": "Loading memory brief..."
          },
          {
            "type": "command",
            "command": "python .claude/hooks/verify-sweep.py",
            "timeout": 10,
            "statusMessage": "Verifying rules..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/improvement-funnel.sh",
            "timeout": 10,
            "statusMessage": "Building improvement queue..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/evolve-trigger.sh",
            "timeout": 5,
            "statusMessage": "Checking evolution thresholds..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/harness-audit.sh",
            "timeout": 10,
            "statusMessage": "Running harness audit..."
          },
          {
            "type": "command",
            "command": "python .claude/hooks/learning-lifecycle.py",
            "timeout": 5,
            "statusMessage": "Learning lifecycle check..."
          },
          {
            "type": "command",
            "command": "python .claude/hooks/skill-detector.py",
            "timeout": 5,
            "statusMessage": "Detecting skill patterns..."
          },
          {
            "type": "command",
            "command": "python .claude/hooks/build-permission-registry.py",
            "timeout": 5,
            "statusMessage": "Building permission registry..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -m dippy",
            "timeout": 5,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-no-verify.sh",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Write|Edit|mcp__filesystem__write_file|mcp__filesystem__edit_file",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/config-protection.sh",
            "timeout": 3,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "python .claude/hooks/security-scan.py",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/tool-gate.py",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "WebFetch|WebSearch|mcp__brave-search__brave_web_search|mcp__brave-search__brave_local_search|mcp__Claude_in_Chrome__get_page_text|mcp__Claude_in_Chrome__read_page",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/content-sanitizer.py",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/activity-log.sh",
            "timeout": 3,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "python .claude/hooks/trace-capture.py",
            "timeout": 2,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "python .claude/hooks/session-trace.py",
            "timeout": 2,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "python .claude/hooks/suggest-compact.py",
            "timeout": 3,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/observe.sh",
            "timeout": 3,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "python .claude/hooks/panic-detector.py",
            "timeout": 3,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "python .claude/hooks/instruction-detector.py",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash .claude/hooks/post-commit-analyzer.sh",
            "timeout": 10,
            "statusMessage": "Analyzing commit..."
          },
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "python .claude/hooks/critic-accuracy-tracker.py",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/acceptance-gate.py",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/skill-usage-tracker.sh",
            "timeout": 3,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/skill-chain-engine.sh",
            "timeout": 5,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/skill-context-tracker.sh",
            "timeout": 2,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "python .claude/hooks/impact-tracker.py",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/file-read-dedup.py",
            "timeout": 2,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "python .claude/hooks/uses-tracker.py",
            "timeout": 2,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.py)|Write(*.py)",
            "command": "bash .claude/hooks/ruff-lint.sh",
            "timeout": 10,
            "statusMessage": "Linting Python..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/learnings-sync.sh",
            "timeout": 5,
            "statusMessage": "",
            "if": "Write(**/learnings/**)|Edit(**/learnings/**)"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/eval-trigger.sh",
            "timeout": 3,
            "statusMessage": "",
            "if": "Write(**SKILL.md)|Edit(**SKILL.md)|Write(**/skills/**)|Edit(**/skills/**)"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/skill-sync.sh",
            "timeout": 5,
            "statusMessage": "Syncing skill copies...",
            "if": "Write(**SKILL.md)|Edit(**SKILL.md)|Write(**/commands/*.md)|Edit(**/commands/*.md)"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/auto-checkpoint-suggest.py",
            "timeout": 3,
            "statusMessage": ""
          },
          {
            "type": "command",
            "if": "Write(.claude/memory/**)|Edit(.claude/memory/**)",
            "command": "python .claude/hooks/memory-integrity-check.py",
            "timeout": 2,
            "statusMessage": ""
          },
          {
            "type": "command",
            "if": "Write(**/learnings/**)|Edit(**/learnings/**)",
            "command": "python .claude/hooks/learning-admission.py",
            "timeout": 3,
            "statusMessage": ""
          },
          {
            "type": "command",
            "if": "Write(**/learnings/**)|Edit(**/learnings/**)",
            "command": "python .claude/hooks/auto-relate.py",
            "timeout": 3,
            "statusMessage": "Auto-linking related learnings..."
          },
          {
            "type": "command",
            "if": "Write(**/learnings/**)|Edit(**/learnings/**)",
            "command": "python .claude/hooks/graduation-check.py",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/permission-auto-approve.sh",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-compact.sh",
            "timeout": 3,
            "statusMessage": "Post-compaction checkpoint reminder"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/completion-guard.sh",
            "timeout": 3,
            "statusMessage": "Checking task completion..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/scribe-reminder.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/cost-tracker.sh",
            "timeout": 5,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/telegram-notify.sh \"🏁 Session dokončena\"",
            "timeout": 5,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "python .claude/hooks/trace-bridge.py",
            "timeout": 5,
            "statusMessage": "Bridging optimization traces..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session-summary.sh",
            "timeout": 5,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/raw-capture.sh",
            "timeout": 5,
            "statusMessage": "Capturing raw session data..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/graph-consolidate.sh",
            "timeout": 10,
            "statusMessage": "Consolidating concept graph..."
          },
          {
            "type": "command",
            "command": "python .claude/hooks/hebbian-consolidate.py",
            "timeout": 10,
            "statusMessage": "Hebbian consolidation..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/compile-trigger.sh",
            "timeout": 5,
            "statusMessage": "Checking compound loop..."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/task-completed.sh",
            "timeout": 15,
            "statusMessage": "Task completed — auto-compound analyzing..."
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/teammate-idle.sh",
            "timeout": 10,
            "statusMessage": "Quality gate — checking teammate output..."
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-failure.sh",
            "timeout": 3,
            "statusMessage": "API error — checking recovery..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/skill-suggest.py",
            "timeout": 3,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "python .claude/hooks/memory-whisper.py",
            "timeout": 3,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "python .claude/hooks/mid-session-capture.py",
            "timeout": 1,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "python .claude/hooks/correction-tracker.py",
            "timeout": 3,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "python .claude/hooks/associative-recall.py",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/permission-denied-logger.sh",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/task-created-gate.sh",
            "timeout": 5,
            "statusMessage": "Checking task budget..."
          }
        ]
      }
    ]
  }
}
