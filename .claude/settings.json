{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/checkpoint-check.sh",
            "timeout": 5,
            "statusMessage": "Checking checkpoint..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/memory-maintenance.sh",
            "timeout": 5,
            "statusMessage": "Checking memory health..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/memory-brief.sh",
            "timeout": 5,
            "statusMessage": "Loading memory brief..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/activity-log.sh",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ruff-lint.sh",
            "timeout": 10,
            "statusMessage": "Linting Python..."
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/permission-auto-approve.sh",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-compact.sh",
            "timeout": 3,
            "statusMessage": "Post-compaction checkpoint reminder"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/scribe-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/task-completed.sh",
            "timeout": 3,
            "statusMessage": "Task completed — checking for learnings..."
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/teammate-idle.sh",
            "timeout": 10,
            "statusMessage": "Quality gate — checking teammate output..."
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-failure.sh",
            "timeout": 3,
            "statusMessage": "API error — checking recovery..."
          }
        ]
      }
    ]
  }
}
