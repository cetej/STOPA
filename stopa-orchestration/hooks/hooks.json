{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/checkpoint-check.sh",
            "timeout": 5,
            "statusMessage": "Checking checkpoint..."
          },
          {
            "type": "command",
            "command": "bash hooks/memory-maintenance.sh",
            "timeout": 5,
            "statusMessage": "Checking memory health..."
          },
          {
            "type": "command",
            "command": "bash hooks/memory-brief.sh",
            "timeout": 5,
            "statusMessage": "Loading memory brief..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -m dippy",
            "timeout": 5,
            "statusMessage": ""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/activity-log.sh",
            "timeout": 3,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "bash hooks/suggest-compact.sh",
            "timeout": 3,
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "bash hooks/observe.sh",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/ruff-lint.sh",
            "timeout": 10,
            "statusMessage": "Linting Python..."
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/permission-auto-approve.sh",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/post-compact.sh",
            "timeout": 3,
            "statusMessage": "Post-compaction checkpoint reminder"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/scribe-reminder.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash hooks/cost-tracker.sh",
            "timeout": 5,
            "statusMessage": ""
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/task-completed.sh",
            "timeout": 3,
            "statusMessage": "Task completed — checking for learnings..."
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/teammate-idle.sh",
            "timeout": 10,
            "statusMessage": "Quality gate — checking teammate output..."
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/stop-failure.sh",
            "timeout": 3,
            "statusMessage": "API error — checking recovery..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python hooks/skill-suggest.py",
            "timeout": 3,
            "statusMessage": ""
          }
        ]
      }
    ]
  }
}
